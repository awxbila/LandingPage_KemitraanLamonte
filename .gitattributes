# Auto detect text files and normalize line endings to LF
* text=auto

# Source code - use CRLF on Windows
*.html text eol=crlf
*.css text eol=crlf
*.js text eol=crlf
*.md text eol=crlf
*.json text eol=crlf
*.svg text eol=crlf

# Binary files
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary

# Documentation
*.md text eol=crlf
README.md text eol=crlf
